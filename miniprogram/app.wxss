page {
  min-height: 100%;
  background: #f7f6f3;
  color: #1a1a1a;
  font-family: PingFang SC, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
}

button::after {
  border: 0;
}

button[disabled],
.is-disabled {
  opacity: 0.45;
  filter: grayscale(0.2);
  pointer-events: none;
}

.pressable {
  transition: transform 140ms ease, opacity 140ms ease, box-shadow 140ms ease, background-color 140ms ease, border-color 140ms ease;
}

.pressable-hover,
.tap-hover {
  opacity: 0.86;
  transform: translateY(2rpx) scale(0.985);
}

.card-hover {
  transform: translateY(-2rpx);
  box-shadow: 0 18rpx 44rpx rgba(26, 26, 26, 0.12);
}

.button-hover {
  opacity: 0.9;
  transform: translateY(2rpx);
  box-shadow: 0 8rpx 18rpx rgba(139, 111, 71, 0.22);
}

.chip-hover {
  border-color: rgba(139, 111, 71, 0.62);
  background: rgba(139, 111, 71, 0.08);
  color: #8b6f47;
}

.input-hover {
  border-color: rgba(139, 111, 71, 0.7);
  box-shadow: 0 0 0 4rpx rgba(139, 111, 71, 0.08);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 24rpx 140rpx;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(139, 111, 71, 0.09) 0, rgba(255, 255, 255, 0) 360rpx),
    #f7f6f3;
}

.page::before {
  content: "";
  position: absolute;
  top: 74rpx;
  right: -110rpx;
  width: 360rpx;
  height: 360rpx;
  border: 2rpx solid rgba(139, 111, 71, 0.08);
  transform: rotate(45deg);
  pointer-events: none;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(26, 26, 26, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 36rpx rgba(26, 26, 26, 0.06);
  padding: 28rpx;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.stack {
  display: flex;
  flex-direction: column;
}

.muted {
  color: #777777;
}

.caption {
  color: #999999;
  font-size: 24rpx;
}

.eyebrow {
  color: #8b6f47;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: uppercase;
}

.title {
  color: #1a1a1a;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.16;
}

.sub-title {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-title {
  margin-bottom: 18rpx;
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 800;
}

.input,
.textarea,
.picker-like {
  width: 100%;
  min-height: 84rpx;
  padding: 0 26rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1a1a1a;
  font-size: 28rpx;
}

.input {
  line-height: 84rpx;
}

.textarea {
  min-height: 220rpx;
  padding-top: 22rpx;
  line-height: 1.6;
}

.picker-like {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #333333;
}

.picker-like::after {
  content: ">";
  color: #8b6f47;
  font-weight: 800;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.94);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #1a1a1a;
  border-radius: 50%;
}

.search-icon::after {
  content: "";
  display: block;
  width: 14rpx;
  height: 4rpx;
  margin: 20rpx 0 0 18rpx;
  border-radius: 4rpx;
  background: #1a1a1a;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  height: 72rpx;
  color: #1a1a1a;
  font-size: 26rpx;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-height: 84rpx;
  padding: 0 32rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #9a7848, #7a5a35);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 22rpx rgba(139, 111, 71, 0.2);
  transition: transform 140ms ease, opacity 140ms ease, box-shadow 140ms ease;
}

.button.secondary {
  border: 1rpx solid #8b6f47;
  background: #ffffff;
  color: #8b6f47;
  box-shadow: none;
}

.button.ghost {
  min-height: 64rpx;
  border: 1rpx solid #dedbd5;
  background: #ffffff;
  color: #333333;
  box-shadow: none;
}

.button.danger {
  background: linear-gradient(135deg, #f44336, #c73028);
  box-shadow: 0 12rpx 22rpx rgba(244, 67, 54, 0.18);
}

.button.small {
  min-height: 58rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 10rpx;
  background: #ffffff;
  color: #666666;
  font-size: 25rpx;
  white-space: nowrap;
  transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease, transform 140ms ease;
}

.chip.active {
  border-color: #8b6f47;
  background: #8b6f47;
  color: #ffffff;
  font-weight: 700;
}

.chip.outline-active {
  border-color: #8b6f47;
  background: rgba(139, 111, 71, 0.08);
  color: #8b6f47;
  font-weight: 700;
}

.hex {
  position: relative;
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.hex-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 94rpx;
  height: 58rpx;
  padding: 0 22rpx;
  background: #8b6f47;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  clip-path: polygon(13% 0, 87% 0, 100% 50%, 87% 100%, 13% 100%, 0 50%);
}

.hex-badge.light {
  border: 2rpx solid #8b6f47;
  background: #ffffff;
  color: #8b6f47;
}

.post-type-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 136rpx;
  height: 58rpx;
  padding: 0 28rpx;
  background: #8b6f47;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 58rpx;
  white-space: nowrap;
  clip-path: polygon(12% 0, 88% 0, 100% 50%, 88% 100%, 12% 100%, 0 50%);
}

.post-type-badge::after {
  content: "";
  position: absolute;
  inset: 6rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  clip-path: polygon(11% 0, 89% 0, 100% 50%, 89% 100%, 11% 100%, 0 50%);
  pointer-events: none;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(26, 26, 26, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(26, 26, 26, 0.05);
  padding: 24rpx;
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.card-title {
  color: #1a1a1a;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.card-text {
  margin-top: 14rpx;
  color: #666666;
  font-size: 27rpx;
  line-height: 1.58;
}

.meta {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  color: #777777;
  font-size: 24rpx;
}

.empty {
  padding: 60rpx 24rpx;
  color: #999999;
  text-align: center;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #333333;
  font-size: 26rpx;
  font-weight: 700;
}

.field-hint {
  color: #999999;
  font-size: 22rpx;
  font-weight: 400;
}

.price {
  color: #8b6f47;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border: 2rpx solid #ffffff;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 36%, #555555 0 16rpx, transparent 17rpx),
    radial-gradient(circle at 50% 102%, #2b2b2b 0 30rpx, transparent 31rpx),
    #d8d2c8;
  box-shadow: 0 6rpx 18rpx rgba(26, 26, 26, 0.14);
}

.image-placeholder {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(26, 26, 26, 0.15), rgba(26, 26, 26, 0.02)),
    repeating-linear-gradient(135deg, #2f3131 0 8rpx, #3b3d3d 8rpx 16rpx);
}

.image-placeholder::before {
  content: "";
  position: absolute;
  inset: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  transform: skew(-10deg);
}

.image-placeholder::after {
  content: "RETROFIT";
  position: absolute;
  right: 16rpx;
  bottom: 14rpx;
  color: rgba(255, 255, 255, 0.56);
  font-size: 20rpx;
  font-weight: 800;
}

.divider {
  height: 1rpx;
  margin: 20rpx 0;
  background: #ece8e2;
}

.hi-icon {
  display: block;
  width: 42rpx;
  height: 42rpx;
}

.hi-icon.small {
  width: 30rpx;
  height: 30rpx;
}

.hi-icon.mini {
  width: 24rpx;
  height: 24rpx;
}

.hi-icon.white {
  filter: none;
}

.icon-button {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
}

.icon-button.outline {
  border: 1rpx solid #dedbd5;
  background: #ffffff;
}

.icon-button.dark {
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  background: rgba(0, 0, 0, 0.24);
}

.icon-label {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.brand-mascot {
  display: block;
  width: 82rpx;
  height: 64rpx;
}
