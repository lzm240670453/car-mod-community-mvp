.messages-page {
  padding-top: 34rpx;
}

.messages-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.messages-title {
  color: #111111;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.messages-subtitle {
  margin-top: 10rpx;
  color: #8b6f47;
  font-size: 24rpx;
  font-weight: 700;
}

.login-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 52rpx 32rpx;
  text-align: center;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
}

.login-button {
  width: 100%;
  margin-top: 12rpx;
}

.message-tab-scroll {
  position: relative;
  z-index: 1;
  margin: 0 -24rpx 22rpx;
  white-space: nowrap;
}

.message-tabs {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 24rpx 8rpx;
}

.message-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 10rpx;
  background: #ffffff;
  color: #666666;
  font-size: 26rpx;
  font-weight: 700;
}

.message-tab.active {
  border-color: #8b6f47;
  background: #8b6f47;
  color: #ffffff;
}

.message-list {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.message-card {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(26, 26, 26, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(26, 26, 26, 0.05);
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.message-card.unread {
  border-color: rgba(139, 111, 71, 0.34);
  box-shadow: 0 12rpx 32rpx rgba(139, 111, 71, 0.12);
}

.message-icon-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(139, 111, 71, 0.09);
}

.unread-dot {
  position: absolute;
  top: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #ffffff;
  border-radius: 50%;
  background: #f44336;
}

.message-main {
  flex: 1;
  min-width: 0;
}

.message-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.message-title {
  flex: 1;
  min-width: 0;
  color: #1a1a1a;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  flex: 0 0 auto;
  color: #999999;
  font-size: 22rpx;
  line-height: 40rpx;
}

.message-content {
  margin-top: 8rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.5;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.message-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
  color: #999999;
  font-size: 23rpx;
}

.message-chip {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: rgba(139, 111, 71, 0.1);
  color: #8b6f47;
  font-size: 22rpx;
  font-weight: 800;
}
