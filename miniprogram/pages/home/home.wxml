<view class="page home-page">
  <view class="home-header">
    <view class="brand-lockup">
      <image class="header-logo" src="/assets/logo/header-logo.png" mode="aspectFit" />
    </view>
    <view class="header-actions">
      <view class="icon-button pressable" hover-class="pressable-hover" bindtap="onHeaderSearch">
        <image class="hi-icon" src="/assets/icons/search-black.svg" mode="aspectFit" />
      </view>
      <view class="icon-button pressable" hover-class="pressable-hover" bindtap="showNotifications">
        <image class="hi-icon" src="/assets/icons/notification-black.svg" mode="aspectFit" />
        <text wx:if="{{unreadCount > 0}}" class="notice-dot">{{unreadCount > 99 ? '99+' : unreadCount}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <scroll-view scroll-x class="filter-scroll">
      <view class="filter-row">
        <view wx:for="{{postTypes}}" wx:key="value" class="chip pressable {{type === item.value ? 'active' : ''}}" data-type="{{item.value}}" hover-class="chip-hover" bindtap="selectType">
          {{item.label}}
        </view>
      </view>
    </scroll-view>
    <view class="search-box home-search" hover-class="input-hover">
      <image class="hi-icon small" src="/assets/icons/search-gray.svg" mode="aspectFit" bindtap="onHeaderSearch" />
      <input class="search-input" value="{{q}}" placeholder="搜索改装案例、问题或车友心得" bindinput="onSearchInput" confirm-type="search" bindconfirm="onSearchConfirm" />
    </view>
  </view>

  <view class="list post-list">
    <view wx:for="{{items}}" wx:key="id" class="card post-card pressable" data-id="{{item.id}}" hover-class="card-hover" bindtap="openPost">
      <view class="post-head">
        <view class="row author">
          <view class="avatar"></view>
          <view class="stack">
            <view class="author-name">车友 {{item.userId}}</view>
            <view class="garage-tag">改装记录 · {{item.createdAtText}}</view>
          </view>
        </view>
        <view class="post-type-badge">{{item.typeText}}</view>
      </view>
      <view class="card-title post-title">{{item.title}}</view>
      <view class="post-media">
        <view class="media-tile image-placeholder"></view>
        <view class="media-tile image-placeholder accent"></view>
        <view class="media-tile image-placeholder dark"></view>
      </view>
      <view class="card-text post-content">{{item.content}}</view>
      <view class="post-actions">
        <view class="action-link pressable" data-id="{{item.id}}" hover-class="pressable-hover" catchtap="likePostInList">
          <image class="hi-icon small" src="/assets/icons/thumbsUp-gray.svg" mode="aspectFit" />
          <text>{{item.likeCount}}</text>
        </view>
        <view class="action-link pressable" data-id="{{item.id}}" hover-class="pressable-hover" catchtap="openComments">
          <image class="hi-icon small" src="/assets/icons/comment-gray.svg" mode="aspectFit" />
          <text>{{item.commentCount}}</text>
        </view>
        <view class="action-link pressable" data-id="{{item.id}}" hover-class="pressable-hover" catchtap="favoritePostInList">
          <image class="hi-icon small" src="/assets/icons/star-gray.svg" mode="aspectFit" />
          <text>收藏 {{item.favoriteCount}}</text>
        </view>
        <view class="action-link more-action pressable" data-id="{{item.id}}" hover-class="pressable-hover" catchtap="showPostActions">
          <image class="hi-icon small" src="/assets/icons/more-gray.svg" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="empty">暂无帖子，去发布第一篇改装日记</view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:if="{{!hasMore && items.length > 0}}" class="empty">没有更多了</view>
</view>
