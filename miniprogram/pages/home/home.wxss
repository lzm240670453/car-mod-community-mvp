.home-page {
  padding-top: 34rpx;
}

.home-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.brand-lockup {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.header-logo {
  display: block;
  width: 360rpx;
  height: 100rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: none;
}

.notice-dot {
  position: absolute;
  top: 0;
  right: 0;
  min-width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #8b6f47;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 28rpx;
  text-align: center;
}

.module-switch {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.module-tab {
  min-height: 126rpx;
  padding: 20rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 22rpx rgba(26, 26, 26, 0.04);
}

.module-tab.active {
  border-color: #8b6f47;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(139, 111, 71, 0.14);
}

.module-label {
  color: #1a1a1a;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.module-summary {
  margin-top: 8rpx;
  color: #666666;
  font-size: 23rpx;
  line-height: 1.35;
}

.module-tab.active .module-summary {
  color: #8b6f47;
}

.knowledge-intro {
  padding: 28rpx;
}

.intro-text {
  margin-top: 10rpx;
  color: #666666;
  font-size: 26rpx;
  line-height: 1.55;
}

.home-search {
  margin-top: 20rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-link {
  min-height: 48rpx;
  padding: 0 14rpx;
  color: #8b6f47;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.knowledge-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
}

.knowledge-tile {
  min-height: 156rpx;
  padding: 14rpx 8rpx;
  border: 1rpx solid rgba(26, 26, 26, 0.08);
  border-radius: 14rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(26, 26, 26, 0.04);
  transition: transform 140ms ease, box-shadow 140ms ease;
}

.tile-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto;
  border-radius: 12rpx;
  background: rgba(139, 111, 71, 0.1);
}

.tile-name {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  margin-top: 10rpx;
  color: #1a1a1a;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.22;
}

.tile-count {
  margin-top: 4rpx;
  color: #8b6f47;
  font-size: 20rpx;
  line-height: 1.25;
}

.knowledge-article {
  padding: 24rpx;
}

.article-kicker {
  margin-bottom: 14rpx;
  color: #8b6f47;
  font-size: 22rpx;
  font-weight: 800;
}

.article-summary {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 10rpx;
  background: rgba(139, 111, 71, 0.08);
  color: #8b6f47;
  font-size: 22rpx;
}

.filter-scroll {
  margin: 10rpx -24rpx 0;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 16rpx 24rpx 18rpx;
}

.post-list {
  position: relative;
  z-index: 1;
}

.post-card {
  padding: 22rpx;
}

.post-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.author {
  min-width: 0;
  gap: 16rpx;
}

.author-name {
  color: #1a1a1a;
  font-size: 27rpx;
  font-weight: 700;
}

.garage-tag {
  display: inline-flex;
  max-width: 360rpx;
  margin-top: 6rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 8rpx;
  color: #666666;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-title {
  margin-top: 22rpx;
}

.post-media {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 16rpx;
}

.media-tile {
  height: 150rpx;
  border-radius: 8rpx;
}

.media-tile.accent {
  filter: sepia(0.2);
}

.media-tile.dark {
  filter: brightness(0.82);
}

.post-content {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.post-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #ece8e2;
  color: #666666;
  font-size: 24rpx;
}

.action-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 8rpx;
  border-radius: 10rpx;
  color: #666666;
}

.more-action {
  justify-content: flex-end;
  min-width: 48rpx;
}

.status-text {
  color: #8b6f47;
}
