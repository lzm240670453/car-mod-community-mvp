.mine-page {
  padding: 0 0 140rpx;
  background: #f7f6f3;
}

.mine-page::before {
  display: none;
}

.profile-hero {
  position: relative;
  min-height: 560rpx;
  padding: 42rpx 32rpx 34rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(5, 10, 13, 0.95)),
    repeating-linear-gradient(135deg, #101820 0 24rpx, #151f27 24rpx 48rpx);
  color: #ffffff;
}

.profile-hero::before {
  content: "";
  position: absolute;
  left: -70rpx;
  top: 100rpx;
  width: 820rpx;
  height: 260rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  transform: rotate(-10deg);
}

.hero-actions {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: flex-end;
  gap: 18rpx;
}

.hero-hex {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 52rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.profile-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  gap: 26rpx;
  margin-top: 130rpx;
}

.profile-avatar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 150rpx;
  height: 150rpx;
  border: 6rpx solid #ffffff;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #f6efe4, #9a7848);
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.3);
}

.profile-mascot {
  width: 142rpx;
  height: 118rpx;
  margin-top: 10rpx;
}

.profile-info {
  flex: 1;
  min-width: 0;
  padding-bottom: 10rpx;
}

.profile-name {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.15;
}

.profile-level {
  display: inline-flex;
  margin-top: 10rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #d6b078;
  font-size: 23rpx;
}

.profile-bio {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.stats-row {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 42rpx;
}

.stat-hex {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-height: 118rpx;
  border: 2rpx solid rgba(214, 176, 120, 0.68);
  clip-path: polygon(20% 0, 80% 0, 100% 50%, 80% 100%, 20% 100%, 0 50%);
}

.stat-value {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.stat-label {
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
}

.mine-page .section {
  margin: 24rpx;
}

.login-panel {
  margin-top: -6rpx;
}

.phone-field,
.selected-field {
  margin-top: 24rpx;
}

.garage-item {
  display: flex;
  gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ece8e2;
}

.garage-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 58rpx;
  height: 52rpx;
  background: #2b2b2b;
  color: #d6b078;
  font-size: 22rpx;
  font-weight: 800;
}

.garage-main {
  flex: 1;
  min-width: 0;
}

.garage-title,
.vehicle-title {
  color: #1a1a1a;
  font-size: 27rpx;
  font-weight: 800;
}

.vehicle-result {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #ece8e2;
  border-radius: 12rpx;
  background: #ffffff;
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.vehicle-result.active {
  border-color: #8b6f47;
  background: rgba(139, 111, 71, 0.08);
}

.two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.mini-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece8e2;
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.mini-cover {
  flex: none;
  width: 150rpx;
  height: 104rpx;
  border-radius: 10rpx;
}

.mini-main {
  flex: 1;
  min-width: 0;
}

.mini-title {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.intent-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece8e2;
}

.report-item {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #ece8e2;
  color: #1a1a1a;
  font-size: 27rpx;
}

.small-empty {
  padding: 32rpx 0;
}
