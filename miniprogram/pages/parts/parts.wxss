.parts-page {
  padding-top: 34rpx;
}

.home-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.brand-lockup {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.header-logo {
  display: block;
  width: 360rpx;
  height: 100rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex: none;
}

.filter-hex {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 58rpx;
  border: 0;
  background: #1a1a1a;
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.filter-hex::before {
  content: "";
  position: absolute;
  inset: 3rpx;
  background: rgba(255, 255, 255, 0.78);
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.filter-hex .hi-icon {
  position: relative;
  z-index: 1;
}

.market-tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #ece8e2;
}

.market-tab {
  position: relative;
  height: 76rpx;
  color: #666666;
  font-size: 30rpx;
  line-height: 76rpx;
  text-align: center;
}

.market-tab.active {
  color: #1a1a1a;
  font-weight: 800;
}

.market-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 86rpx;
  height: 5rpx;
  border-radius: 5rpx;
  background: #8b6f47;
  transform: translateX(-50%);
}

.parts-search {
  margin-bottom: 18rpx;
}

.category-scroll {
  margin: 0 -24rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 24rpx 8rpx;
}

.result-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #1a1a1a;
  font-size: 26rpx;
  font-weight: 700;
}

.sort-trigger {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-height: 48rpx;
  padding: 0 10rpx;
  border-radius: 10rpx;
  color: #666666;
  font-size: 24rpx;
}

.parts-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  position: relative;
  z-index: 1;
}

.part-card {
  overflow: hidden;
  border: 1rpx solid rgba(26, 26, 26, 0.09);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(26, 26, 26, 0.05);
  transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
}

.part-cover {
  position: relative;
  height: 210rpx;
}

.part-badge {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 74rpx;
  height: 66rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.part-badge.sell {
  background: #4caf50;
}

.part-badge.buy {
  background: #ff9800;
}

.part-body {
  padding: 18rpx;
}

.part-title {
  min-height: 76rpx;
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.price-row {
  margin-top: 12rpx;
}

.condition {
  padding: 6rpx 12rpx;
  border: 1rpx solid #dedbd5;
  border-radius: 10rpx;
  color: #777777;
  font-size: 22rpx;
  white-space: nowrap;
}

.part-meta,
.fitment {
  margin-top: 10rpx;
  color: #777777;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.part-meta {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.seller-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #ece8e2;
  color: #666666;
  font-size: 23rpx;
}

.mini-avatar {
  width: 36rpx;
  height: 36rpx;
  box-shadow: none;
}
