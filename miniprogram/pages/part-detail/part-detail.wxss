.part-detail-page {
  padding-top: 24rpx;
}

.part-hero {
  padding: 28rpx;
}

.hex-badge.buy {
  background: #ff9800;
}

.detail-title {
  margin-top: 24rpx;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 14rpx;
  color: #777777;
  font-size: 24rpx;
}

.part-cover {
  height: 360rpx;
  margin-top: 24rpx;
  border-radius: 14rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 24rpx;
}

.image-grid image {
  width: 100%;
  height: 160rpx;
  border-radius: 8rpx;
  background: #ece8e2;
}

.spec-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 24rpx;
}

.spec-item {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-height: 104rpx;
  padding: 18rpx;
  border: 1rpx solid #ece8e2;
  border-radius: 12rpx;
  background: #fbfaf8;
}

.spec-item text:last-child {
  display: block;
  color: #1a1a1a;
  font-size: 27rpx;
  font-weight: 800;
}

.content {
  margin-top: 24rpx;
  color: #333333;
  font-size: 29rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.notice {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
  border-radius: 12rpx;
  background: #fff7ed;
  color: #9a5b1f;
  font-size: 25rpx;
  line-height: 1.6;
}

.favorite-button {
  margin-top: 22rpx;
}

.mini-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ece8e2;
  color: #1a1a1a;
  font-size: 27rpx;
}

.hex-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 42rpx;
  height: 38rpx;
  margin-top: 6rpx;
  background: #8b6f47;
  clip-path: polygon(25% 4%, 75% 4%, 100% 50%, 75% 96%, 25% 96%, 0 50%);
}

.small-empty {
  padding: 32rpx 0;
}

.intent-input {
  min-height: 170rpx;
  margin: 20rpx 0 16rpx;
}

.report-input {
  margin: 20rpx 0 16rpx;
}
