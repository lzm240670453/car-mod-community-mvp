.detail-page {
  padding-top: 24rpx;
}

.detail-hero {
  padding: 28rpx;
}

.post-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.author {
  gap: 16rpx;
}

.author-name {
  color: #1a1a1a;
  font-size: 28rpx;
  font-weight: 800;
}

.garage-tag {
  margin-top: 6rpx;
  color: #777777;
  font-size: 23rpx;
}

.detail-title {
  margin-top: 28rpx;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 14rpx;
  color: #777777;
  font-size: 24rpx;
}

.content {
  margin-top: 26rpx;
  color: #333333;
  font-size: 29rpx;
  line-height: 1.75;
  white-space: pre-wrap;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 24rpx;
}

.image-grid image {
  width: 100%;
  height: 150rpx;
  border-radius: 8rpx;
  background: #ece8e2;
}

.detail-cover {
  height: 260rpx;
  margin-top: 24rpx;
  border-radius: 12rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #ece8e2;
}

.mini-avatar {
  width: 48rpx;
  height: 48rpx;
  flex: none;
  box-shadow: none;
}

.comment-main {
  flex: 1;
  min-width: 0;
}

.comment-author {
  color: #1a1a1a;
  font-size: 25rpx;
  font-weight: 700;
}

.comment-content {
  margin: 8rpx 0;
  color: #333333;
  font-size: 27rpx;
  line-height: 1.55;
}

.comment-input {
  min-height: 150rpx;
  margin: 22rpx 0 16rpx;
}

.small-empty {
  padding: 32rpx 0;
}

.report-panel .caption {
  margin-top: 8rpx;
}

.report-input {
  margin: 20rpx 0 16rpx;
}
